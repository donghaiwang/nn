<mujoco model="Humanoid-Arm-Grasp">
  <option timestep="0.005"/>

  <visual>
    <map force="0.1" zfar="30"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global offwidth="2560" offheight="1440" elevation="-20" azimuth="120"/>
  </visual>

  <statistic center="0 0 0.7"/>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
    <texture name="body" type="cube" builtin="flat" mark="cross" width="128" height="128" rgb1="0.8 0.6 0.4" rgb2="0.8 0.6 0.4" markrgb="1 1 1"/>
    <material name="body" texture="body" texuniform="true" rgba="0.8 0.6 .4 1"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    <!-- 抓取目标物体材质 -->
    <material name="target_obj" rgba="0.9 0.2 0.2 1"/>
  </asset>

  <default>
    <motor ctrlrange="-2 2" ctrllimited="true"/>  <!-- 增大控制范围，适配抓取动作 -->
    <default class="body">
      <!-- 手臂相关geom默认参数 -->
      <geom type="capsule" condim="1" friction=".9" solimp=".9 .99 .003" solref=".015 1" material="body" group="1"/>
      <default class="arm_upper">
        <geom size=".04"/>
      </default>
      <default class="arm_lower">
        <geom size=".031"/>
      </default>
      <default class="hand">
        <geom type="sphere" size=".05"/>  <!-- 增大手部尺寸，方便抓取 -->
      </default>

      <!-- 手臂相关joint默认参数 -->
      <joint type="hinge" damping=".3" stiffness="5" armature=".01" limited="true" solimplimit="0 .99 .01"/>
      <default class="shoulder">
        <joint range="-120 90"/>  <!-- 扩大肩膀关节范围，适配向前抓取 -->
      </default>
      <default class="elbow">
        <joint range="-150 80" stiffness="2"/>  <!-- 扩大手肘范围 -->
      </default>
    </default>
  </default>

  <worldbody>
    <geom name="floor" size="0 0 .05" type="plane" material="grid" condim="3"/>
    <light name="spotlight" mode="targetbodycom" target="torso" diffuse=".8 .8 .8" specular="0.3 0.3 0.3" pos="0 -6 4" cutoff="30"/>
    <light name="top" pos="0 0 2" mode="trackcom"/>

    <!-- 抓取目标物体（地面上的小球） -->
    <body name="target_ball" pos="0.3 0 0.1">
      <geom name="target_ball_geom" type="sphere" size=".06" material="target_obj" condim="3"/>
      <freejoint name="target_ball_joint"/>  <!-- 物体可被推动/抓取 -->
    </body>

    <!-- 简化的躯干（固定在地面） -->
    <body name="torso" pos="0 0 0.5" childclass="body">
      <camera name="back" pos="-3 0 1" xyaxes="0 -1 0 1 0 2" mode="trackcom"/>
      <camera name="side" pos="0 -3 1" xyaxes="1 0 0 0 1 2" mode="trackcom"/>
      <geom name="torso" fromto="0 -.07 0 0 .07 0" size=".07"/>

      <!-- 右臂（主要控制的抓取臂） -->
      <body name="upper_arm_right" pos="0 -.17 .06">
        <joint name="shoulder1_right" axis="2 1 1"  class="shoulder"/>
        <joint name="shoulder2_right" axis="0 -1 1" class="shoulder"/>
        <geom name="upper_arm_right" fromto="0 0 0 .16 -.16 -.16" class="arm_upper"/>
        <body name="lower_arm_right" pos=".18 -.18 -.18">
          <joint name="elbow_right" axis="0 -1 1" class="elbow"/>
          <geom name="lower_arm_right" fromto=".01 .01 .01 .17 .17 .17" class="arm_lower"/>
          <body name="hand_right" pos=".18 .18 .18">
            <!-- 手部抓取碰撞体（扩大接触范围） -->
            <geom name="hand_right_main" zaxis="1 1 1" class="hand"/>
            <geom name="hand_right_grasp" type="capsule" fromto="0 0 0 0.08 0.08 0" size=".02" material="body"/>
          </body>
        </body>
      </body>

      <!-- 左臂（保持原有结构） -->
      <body name="upper_arm_left" pos="0 .17 .06">
        <joint name="shoulder1_left" axis="-2 1 -1" class="shoulder"/>
        <joint name="shoulder2_left" axis="0 -1 -1"  class="shoulder"/>
        <geom name="upper_arm_left" fromto="0 0 0 .16 .16 -.16" class="arm_upper"/>
        <body name="lower_arm_left" pos=".18 .18 -.18">
          <joint name="elbow_left" axis="0 -1 -1" class="elbow"/>
          <geom name="lower_arm_left" fromto=".01 -.01 .01 .17 -.17 .17" class="arm_lower"/>
          <body name="hand_left" pos=".18 -.18 .18">
            <geom name="hand_left" zaxis="1 -1 1" class="hand"/>
          </body>
        </body>
      </body>
    </body>
  </worldbody>

  <!-- 手臂执行器（新增手部抓取相关的阻尼优化） -->
  <actuator>
    <motor name="shoulder1_right" gear="30"  joint="shoulder1_right"/>
    <motor name="shoulder2_right" gear="30"  joint="shoulder2_right"/>
    <motor name="elbow_right"     gear="50"  joint="elbow_right"/>
    <motor name="shoulder1_left"  gear="20"  joint="shoulder1_left"/>
    <motor name="shoulder2_left"  gear="20"  joint="shoulder2_left"/>
    <motor name="elbow_left"      gear="40"  joint="elbow_left"/>
  </actuator>

  <!-- 抓取约束（接触时自动吸附） -->
  <contact>
    <pair geom1="hand_right_grasp" geom2="target_ball_geom" solref=".01 1" solimp=".9 .99 .001" friction=".9"/>
  </contact>
</mujoco>