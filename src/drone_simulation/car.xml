<?xml version="1.0" encoding="UTF-8"?>
<mujoco model="quadrotor_city_traffic">
  <option timestep="0.005"/>

  <worldbody>
    <!-- 光照 -->
    <light name="sun" pos="0 0 10"/>

    <!-- 地面 -->
    <geom name="ground" type="plane" pos="0 0 0" size="12 12 0.1" rgba="0.3 0.5 0.3 1"/>

    <!-- 道路 -->
    <geom name="road_h" type="box" pos="0 0 0.01" size="10 2 0.05" rgba="0.2 0.2 0.2 1"/>
    <geom name="road_v" type="box" pos="0 0 0.01" size="2 10 0.05" rgba="0.2 0.2 0.2 1"/>

    <!-- 道路标线 -->
    <geom name="line_h" type="box" pos="0 0 0.04" size="10 0.1 0.02" rgba="1 1 0 1"/>
    <geom name="line_v" type="box" pos="0 0 0.04" size="0.1 10 0.02" rgba="1 1 0 1"/>

    <!-- 红绿灯 - 北 -->
    <body name="traffic_light_north" pos="0 3 0.5">
      <geom name="pole_n" type="cylinder" size="0.05 0.8" pos="0 0 0.5" rgba="0.3 0.3 0.3 1"/>
      <geom name="red_n" type="sphere" size="0.1" pos="0 0.15 1.0" rgba="1 0 0 1"/>
      <geom name="yellow_n" type="sphere" size="0.1" pos="0 0 0.9" rgba="1 1 0 1"/>
      <geom name="green_n" type="sphere" size="0.1" pos="0 -0.15 0.8" rgba="0 1 0 1"/>
    </body>

    <!-- 红绿灯 - 南 -->
    <body name="traffic_light_south" pos="0 -3 0.5">
      <geom name="pole_s" type="cylinder" size="0.05 0.8" pos="0 0 0.5" rgba="0.3 0.3 0.3 1"/>
      <geom name="red_s" type="sphere" size="0.1" pos="0 0.15 1.0" rgba="1 0 0 1"/>
      <geom name="yellow_s" type="sphere" size="0.1" pos="0 0 0.9" rgba="1 1 0 1"/>
      <geom name="green_s" type="sphere" size="0.1" pos="0 -0.15 0.8" rgba="0 1 0 1"/>
    </body>

    <!-- 红绿灯 - 东 -->
    <body name="traffic_light_east" pos="3 0 0.5">
      <geom name="pole_e" type="cylinder" size="0.05 0.8" pos="0 0 0.5" rgba="0.3 0.3 0.3 1"/>
      <geom name="red_e" type="sphere" size="0.1" pos="0 0.15 1.0" rgba="1 0 0 1"/>
      <geom name="yellow_e" type="sphere" size="0.1" pos="0 0 0.9" rgba="1 1 0 1"/>
      <geom name="green_e" type="sphere" size="0.1" pos="0 -0.15 0.8" rgba="0 1 0 1"/>
    </body>

    <!-- 红绿灯 - 西 -->
    <body name="traffic_light_west" pos="-3 0 0.5">
      <geom name="pole_w" type="cylinder" size="0.05 0.8" pos="0 0 0.5" rgba="0.3 0.3 0.3 1"/>
      <geom name="red_w" type="sphere" size="0.1" pos="0 0.15 1.0" rgba="1 0 0 1"/>
      <geom name="yellow_w" type="sphere" size="0.1" pos="0 0 0.9" rgba="1 1 0 1"/>
      <geom name="green_w" type="sphere" size="0.1" pos="0 -0.15 0.8" rgba="0 1 0 1"/>
    </body>

    <!-- 建筑 -->
    <body name="building1" pos="5 5 0.5">
      <geom name="b1" type="box" size="1 1 1" rgba="0.5 0.5 0.5 1"/>
    </body>

    <body name="building2" pos="-5 5 0.5">
      <geom name="b2" type="box" size="1 1 1" rgba="0.7 0.3 0.2 1"/>
    </body>

    <body name="building3" pos="5 -5 0.5">
      <geom name="b3" type="box" size="1 1 1" rgba="0.3 0.7 0.2 1"/>
    </body>

    <body name="building4" pos="-5 -5 0.5">
      <geom name="b4" type="box" size="1 1 1" rgba="0.2 0.3 0.7 1"/>
    </body>

    <!-- 树木 -->
    <body name="tree1" pos="2 2 0.5">
      <geom name="trunk1" type="cylinder" size="0.1 0.5" pos="0 0 0.3" rgba="0.5 0.3 0.1 1"/>
      <geom name="leaves1" type="sphere" size="0.2" pos="0 0 0.7" rgba="0.2 0.7 0.2 1"/>
    </body>

    <body name="tree2" pos="-2 2 0.5">
      <geom name="trunk2" type="cylinder" size="0.1 0.5" pos="0 0 0.3" rgba="0.5 0.3 0.1 1"/>
      <geom name="leaves2" type="sphere" size="0.2" pos="0 0 0.7" rgba="0.2 0.7 0.2 1"/>
    </body>

    <!-- 无人机 -->
    <body name="quadrotor" pos="0 0 0.2">
      <joint name="quad_free_joint" type="free"/>
      <geom name="body" type="sphere" size="0.15" rgba="0.1 0.1 0.1 1"/>
      <geom name="arm1" type="capsule" fromto="0.1 0.1 0 0.25 0.25 0" size="0.01"/>
      <geom name="arm2" type="capsule" fromto="0.1 -0.1 0 0.25 -0.25 0" size="0.01"/>
      <geom name="arm3" type="capsule" fromto="-0.1 -0.1 0 -0.25 -0.25 0" size="0.01"/>
      <geom name="arm4" type="capsule" fromto="-0.1 0.1 0 -0.25 0.25 0" size="0.01"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor1" joint="quad_free_joint" gear="1"/>
  </actuator>
</mujoco>