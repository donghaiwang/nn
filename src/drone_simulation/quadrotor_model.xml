<?xml version="1.0" encoding="UTF-8"?>
<mujoco model="quadrotor_city_env">
  <option timestep="0.005" iterations="100" tolerance="1e-10">
    <flag contact="enable" energy="enable"/>
  </option>
  <size nconmax="100" njmax="200"/>

  <default>
    <joint damping="0.001" frictionloss="0.001"/>
    <geom solref="0.02 1" solimp="0.9 0.95 0.01" margin="0.001"/>
  </default>

  <asset>
    <!-- 天空盒纹理 -->
    <texture name="skybox" type="skybox" builtin="gradient" rgb1="0.3 0.5 0.9" rgb2="0.6 0.8 1.0" width="800" height="800"/>

    <!-- 地面纹理 -->
    <texture name="grass" type="2d" builtin="checker" rgb1="0.2 0.5 0.2" rgb2="0.3 0.6 0.3" width="512" height="512"/>
    <material name="grass_mat" texture="grass" texrepeat="20 20"/>

    <!-- 道路纹理 -->
    <texture name="asphalt" type="2d" builtin="checker" rgb1="0.15 0.15 0.15" rgb2="0.25 0.25 0.25" width="128" height="128"/>
    <material name="asphalt_mat" texture="asphalt" texrepeat="10 10"/>

    <!-- 建筑物材质 -->
    <material name="concrete" rgba="0.5 0.5 0.5 1"/>
    <material name="brick" rgba="0.7 0.3 0.2 1"/>
    <material name="glass" rgba="0.6 0.8 1 0.6"/>
    <material name="metal" rgba="0.3 0.3 0.3 1"/>
    <material name="wood" rgba="0.6 0.4 0.2 1"/>

    <!-- 无人机材质 -->
    <material name="carbon" rgba="0.1 0.1 0.1 1"/>
    <material name="motor" rgba="0.3 0.3 0.35 1"/>
    <material name="propeller" rgba="0.05 0.05 0.05 0.9"/>
  </asset>

  <worldbody>
    <!-- 光照 -->
    <light name="sun" pos="30 30 50" dir="-1 -1 -1" directional="true" castshadow="true" diffuse="1 1 1" ambient="0.4 0.4 0.4"/>
    <light name="fill1" pos="-20 20 30" dir="0.5 -0.5 -1" directional="true" castshadow="false" diffuse="0.4 0.4 0.4"/>

    <!-- 地面 -->
    <geom name="ground" type="plane" pos="0 0 -0.1" size="40 40 0.1" material="grass_mat" condim="3"/>

    <!-- 道路 -->
    <geom name="road_h" type="box" pos="0 0 0" size="30 4 0.05" material="asphalt_mat"/>
    <geom name="road_v" type="box" pos="0 0 0" size="4 30 0.05" material="asphalt_mat"/>

    <!-- 道路标线 -->
    <geom name="line_h" type="box" pos="0 0 0.04" size="30 0.1 0.02" rgba="1 1 0 1"/>
    <geom name="line_v" type="box" pos="0 0 0.04" size="0.1 30 0.02" rgba="1 1 0 1"/>

    <!-- ========== 无人机 ========== -->
    <body name="quadrotor" pos="0 0 0.8">
      <joint name="quad_free_joint" type="free"/>

      <!-- 主体 -->
      <geom name="body_center" type="cylinder" size="0.12 0.04" material="carbon"/>
      <geom name="body_top" type="cylinder" size="0.08 0.01" pos="0 0 0.05" material="carbon"/>
      <geom name="body_bottom" type="cylinder" size="0.08 0.01" pos="0 0 -0.05" material="carbon"/>

      <!-- 机臂 -->
      <geom name="arm_1" type="capsule" fromto="0.1 0.1 0 0.35 0.35 0" size="0.012" material="carbon"/>
      <geom name="arm_2" type="capsule" fromto="0.1 -0.1 0 0.35 -0.35 0" size="0.012" material="carbon"/>
      <geom name="arm_3" type="capsule" fromto="-0.1 -0.1 0 -0.35 -0.35 0" size="0.012" material="carbon"/>
      <geom name="arm_4" type="capsule" fromto="-0.1 0.1 0 -0.35 0.35 0" size="0.012" material="carbon"/>

      <!-- 电机1 -->
      <body name="motor_1" pos="0.35 0.35 0">
        <geom name="motor_housing_1" type="cylinder" size="0.04 0.025" material="motor"/>
        <body name="rotor_1" pos="0 0 0.05">
          <joint name="rotor_1_joint" type="hinge" axis="0 0 1"/>
          <geom name="propeller_1" type="cylinder" size="0.15 0.008" material="propeller"/>
        </body>
      </body>

      <!-- 电机2 -->
      <body name="motor_2" pos="0.35 -0.35 0">
        <geom name="motor_housing_2" type="cylinder" size="0.04 0.025" material="motor"/>
        <body name="rotor_2" pos="0 0 0.05">
          <joint name="rotor_2_joint" type="hinge" axis="0 0 1"/>
          <geom name="propeller_2" type="cylinder" size="0.15 0.008" material="propeller"/>
        </body>
      </body>

      <!-- 电机3 -->
      <body name="motor_3" pos="-0.35 -0.35 0">
        <geom name="motor_housing_3" type="cylinder" size="0.04 0.025" material="motor"/>
        <body name="rotor_3" pos="0 0 0.05">
          <joint name="rotor_3_joint" type="hinge" axis="0 0 1"/>
          <geom name="propeller_3" type="cylinder" size="0.15 0.008" material="propeller"/>
        </body>
      </body>

      <!-- 电机4 -->
      <body name="motor_4" pos="-0.35 0.35 0">
        <geom name="motor_housing_4" type="cylinder" size="0.04 0.025" material="motor"/>
        <body name="rotor_4" pos="0 0 0.05">
          <joint name="rotor_4_joint" type="hinge" axis="0 0 1"/>
          <geom name="propeller_4" type="cylinder" size="0.15 0.008" material="propeller"/>
        </body>
      </body>

      <!-- LED灯 -->
      <geom name="led_front" type="sphere" size="0.015" pos="0.15 0 0.03" rgba="1 0 0 1"/>
      <geom name="led_back" type="sphere" size="0.015" pos="-0.15 0 0.03" rgba="0 0 1 1"/>
      <geom name="led_left" type="sphere" size="0.015" pos="0 0.15 0.03" rgba="0 1 0 1"/>
      <geom name="led_right" type="sphere" size="0.015" pos="0 -0.15 0.03" rgba="0 1 0 1"/>
    </body>

    <!-- ========== 建筑物 ========== -->

    <!-- 办公楼 -->
    <body name="building_office" pos="5 5 0.5">
      <geom name="office_base" type="box" size="1.2 1.2 0.5" pos="0 0 0.5" material="concrete"/>
      <geom name="office_mid" type="box" size="1.1 1.1 0.5" pos="0 0 1.2" material="glass"/>
      <geom name="office_top" type="box" size="1.0 1.0 0.4" pos="0 0 1.9" material="concrete"/>
    </body>

    <!-- 塔楼 -->
    <body name="building_tower" pos="8 4 0.5">
      <geom name="tower_base" type="cylinder" size="0.8 0.5" pos="0 0 0.5" material="concrete"/>
      <geom name="tower_mid" type="cylinder" size="0.7 0.6" pos="0 0 1.3" material="glass"/>
      <geom name="tower_top" type="cylinder" size="0.5 0.4" pos="0 0 2.1" material="concrete"/>
    </body>

    <!-- 公寓楼 -->
    <body name="building_apartment" pos="3 8 0.5">
      <geom name="apt_base" type="box" size="1.5 1.5 0.4" pos="0 0 0.4" material="brick"/>
      <geom name="apt_1" type="box" size="1.4 1.4 0.4" pos="0 0 1.0" material="brick"/>
      <geom name="apt_2" type="box" size="1.3 1.3 0.4" pos="0 0 1.6" material="brick"/>
    </body>

    <!-- 商店 -->
    <body name="building_shop" pos="-5 5 0.5">
      <geom name="shop_main" type="box" size="1.5 1.5 0.6" pos="0 0 0.6" material="brick"/>
      <geom name="shop_roof" type="box" size="1.6 1.6 0.1" pos="0 0 1.2" material="concrete"/>
    </body>

    <!-- 咖啡馆 -->
    <body name="building_cafe" pos="-8 4 0.5">
      <geom name="cafe_base" type="box" size="1.2 1.2 0.4" pos="0 0 0.4" material="brick"/>
      <geom name="cafe_walls" type="box" size="1.1 1.1 0.4" pos="0 0 1.0" material="brick"/>
    </body>

    <!-- 住宅1 -->
    <body name="building_house1" pos="-5 -5 0.5">
      <geom name="house1_base" type="box" size="1.2 1.2 0.3" pos="0 0 0.3" material="brick"/>
      <geom name="house1_walls" type="box" size="1.1 1.1 0.3" pos="0 0 0.8" material="brick"/>
    </body>

    <!-- 住宅2 -->
    <body name="building_house2" pos="-8 -5 0.5">
      <geom name="house2_base" type="box" size="1.2 1.2 0.3" pos="0 0 0.3" material="brick"/>
      <geom name="house2_walls" type="box" size="1.1 1.1 0.3" pos="0 0 0.8" material="brick"/>
    </body>

    <!-- 学校 -->
    <body name="building_school" pos="5 -5 0.5">
      <geom name="school_base" type="box" size="1.8 1.8 0.4" pos="0 0 0.4" material="concrete"/>
      <geom name="school_mid" type="box" size="1.7 1.7 0.4" pos="0 0 1.0" material="brick"/>
      <geom name="school_top" type="box" size="1.6 1.6 0.4" pos="0 0 1.6" material="concrete"/>
    </body>

    <!-- 图书馆 -->
    <body name="building_library" pos="8 -5 0.5">
      <geom name="library_base" type="box" size="1.4 1.4 0.5" pos="0 0 0.5" material="brick"/>
    </body>

    <!-- 公园设施 -->
    <body name="building_park" pos="5 -8 0.5">
      <geom name="park_bench" type="box" size="0.5 0.2 0.1" pos="0.3 0 0.1" material="wood"/>
      <geom name="park_table" type="cylinder" size="0.3 0.1" pos="0 0 0.1" material="concrete"/>
    </body>

    <!-- 路灯 -->
    <body name="light_1" pos="3 3 0.5">
      <geom name="pole_1" type="cylinder" size="0.05 1.2" pos="0 0 0.8" material="metal"/>
      <geom name="head_1" type="sphere" size="0.1" pos="0 0 1.4" rgba="0.9 0.9 0.8 1"/>
    </body>

    <body name="light_2" pos="-3 3 0.5">
      <geom name="pole_2" type="cylinder" size="0.05 1.2" pos="0 0 0.8" material="metal"/>
      <geom name="head_2" type="sphere" size="0.1" pos="0 0 1.4" rgba="0.9 0.9 0.8 1"/>
    </body>

    <body name="light_3" pos="3 -3 0.5">
      <geom name="pole_3" type="cylinder" size="0.05 1.2" pos="0 0 0.8" material="metal"/>
      <geom name="head_3" type="sphere" size="0.1" pos="0 0 1.4" rgba="0.9 0.9 0.8 1"/>
    </body>

    <body name="light_4" pos="-3 -3 0.5">
      <geom name="pole_4" type="cylinder" size="0.05 1.2" pos="0 0 0.8" material="metal"/>
      <geom name="head_4" type="sphere" size="0.1" pos="0 0 1.4" rgba="0.9 0.9 0.8 1"/>
    </body>

    <!-- 树木 -->
    <body name="tree_1" pos="2 2 0.5">
      <geom name="trunk_1" type="cylinder" size="0.1 0.8" pos="0 0 0.6" rgba="0.5 0.3 0.1 1"/>
      <geom name="leaves_1" type="sphere" size="0.25" pos="0 0 1.1" rgba="0.2 0.7 0.2 1"/>
    </body>

    <body name="tree_2" pos="-2 2 0.5">
      <geom name="trunk_2" type="cylinder" size="0.1 0.8" pos="0 0 0.6" rgba="0.5 0.3 0.1 1"/>
      <geom name="leaves_2" type="sphere" size="0.25" pos="0 0 1.1" rgba="0.2 0.7 0.2 1"/>
    </body>

    <body name="tree_3" pos="2 -2 0.5">
      <geom name="trunk_3" type="cylinder" size="0.1 0.8" pos="0 0 0.6" rgba="0.5 0.3 0.1 1"/>
      <geom name="leaves_3" type="sphere" size="0.25" pos="0 0 1.1" rgba="0.2 0.7 0.2 1"/>
    </body>

    <body name="tree_4" pos="-2 -2 0.5">
      <geom name="trunk_4" type="cylinder" size="0.1 0.8" pos="0 0 0.6" rgba="0.5 0.3 0.1 1"/>
      <geom name="leaves_4" type="sphere" size="0.25" pos="0 0 1.1" rgba="0.2 0.7 0.2 1"/>
    </body>

    <!-- 汽车 -->
    <body name="car_1" pos="2 0 0.15">
      <geom name="car1_body" type="box" size="0.5 0.2 0.15" pos="0 0 0.15" rgba="0.2 0.3 0.8 1"/>
      <geom name="car1_wheel1" type="cylinder" size="0.08 0.05" pos="0.25 0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
      <geom name="car1_wheel2" type="cylinder" size="0.08 0.05" pos="0.25 -0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
      <geom name="car1_wheel3" type="cylinder" size="0.08 0.05" pos="-0.25 0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
      <geom name="car1_wheel4" type="cylinder" size="0.08 0.05" pos="-0.25 -0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
    </body>

    <body name="car_2" pos="-2 0 0.15">
      <geom name="car2_body" type="box" size="0.5 0.2 0.15" pos="0 0 0.15" rgba="0.8 0.2 0.2 1"/>
      <geom name="car2_wheel1" type="cylinder" size="0.08 0.05" pos="0.25 0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
      <geom name="car2_wheel2" type="cylinder" size="0.08 0.05" pos="0.25 -0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
      <geom name="car2_wheel3" type="cylinder" size="0.08 0.05" pos="-0.25 0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
      <geom name="car2_wheel4" type="cylinder" size="0.08 0.05" pos="-0.25 -0.15 0.08" euler="1.57 0 0" rgba="0.1 0.1 0.1 1"/>
    </body>
  </worldbody>

  <actuator>
    <motor name="motor_1" joint="rotor_1_joint" gear="80" ctrllimited="true" ctrlrange="0 1000"/>
    <motor name="motor_2" joint="rotor_2_joint" gear="80" ctrllimited="true" ctrlrange="0 1000"/>
    <motor name="motor_3" joint="rotor_3_joint" gear="80" ctrllimited="true" ctrlrange="0 1000"/>
    <motor name="motor_4" joint="rotor_4_joint" gear="80" ctrllimited="true" ctrlrange="0 1000"/>
  </actuator>
</mujoco>